---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { format } from 'date-fns';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BlogLayout title="Blog — Lukas Andersen" description="Thoughts on software engineering, technology, and design.">
  <div class="min-h-screen">
    <div class="max-w-[680px] mx-auto px-6 py-20">
      <header class="mb-16">
        <h1 class="text-[28px] font-semibold tracking-[0.03em] text-text-primary mb-4">Blog</h1>
        <p class="text-text-secondary">
          Thoughts on software engineering, technology, and design.
        </p>
      </header>

      <div class="space-y-12">
        {posts.length === 0 ? (
          <p class="text-text-muted">No posts yet. Check back soon.</p>
        ) : (
          posts.map((post) => (
            <article>
              <a href={`/blog/${post.id}`} class="block group">
                <time class="text-[14px] text-text-secondary">
                  {format(post.data.date, 'MMMM d, yyyy')}
                </time>
                <h2 class="text-[22px] font-semibold tracking-[0.02em] text-text-primary mt-2 group-hover:text-accent">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-text-secondary mt-3 leading-[1.7]">
                    {post.data.description}
                  </p>
                )}
              </a>
            </article>
          ))
        )}
      </div>
    </div>
  </div>
</BlogLayout>
